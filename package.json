{
  "name": "gh-quest",
  "version": "0.2.0",
  "description": "Find good-first-issues that genuinely need contributors — filters out raced and bot-gated issues.",
  "keywords": [
    "github",
    "open-source",
    "contributing",
    "good-first-issue",
    "cli",
    "octokit"
  ],
  "author": "yokesh-kumar-M",
  "license": "MIT",
  "homepage": "https://github.com/yokesh-kumar-M/gh-quest",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yokesh-kumar-M/gh-quest.git"
  },
  "bugs": {
    "url": "https://github.com/yokesh-kumar-M/gh-quest/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gh-quest": "./bin/gh-quest.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@octokit/plugin-throttling": "^10.0.0",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
